@model List<UserModel>
@{
	// TODO: Add more information to each user when the website is a bit more developed
	ViewData["Title"] = "Users";
}

<h1>Users</h1>

<table class="table">
	<thead>
		<tr>
			<th>Username</th>
		</tr>
	</thead>
	<tbody>
		@foreach (var user in Model)
		{
			<tr>
				<td class="align-middle">
					<a asp-area="" asp-controller="User" asp-action="Profile" asp-route-id="@user.Id">@Html.DisplayFor(_ => user.UserName)</a>
				</td>
			</tr>
		}
	</tbody>
</table>
